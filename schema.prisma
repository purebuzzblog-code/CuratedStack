// CuratedStack - Prisma schema
// Run `npx prisma generate` after any change, and `npm run db:push` (or db:migrate) to sync the DB.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth / Users
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  EDITOR
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // bcrypt hash, used by Credentials provider
  role          Role      @default(ADMIN)

  accounts Account[]
  sessions Session[]
  posts    Post[]
  logs     ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Standard Auth.js (NextAuth) adapter models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Blog
// ---------------------------------------------------------------------------

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  content     String // rich HTML/Markdown content
  status      PostStatus @default(DRAFT)
  featuredImage String?

  // SEO
  seoTitle       String?
  seoDescription String?

  // Computed/stored for display; recalculated on save
  wordCount   Int @default(0)
  readingTime Int @default(1) // in minutes

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([slug])
}

// ---------------------------------------------------------------------------
// The Stack (affiliate tools)
// ---------------------------------------------------------------------------

model Tool {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String
  category     String
  affiliateUrl String
  logo         String?
  featured     Boolean  @default(false)
  visible      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible])
  @@index([featured])
}

// ---------------------------------------------------------------------------
// Site-wide configuration
// ---------------------------------------------------------------------------

model Footer {
  id        String @id @default("footer")
  facebook  String @default("")
  twitter   String @default("")
  linkedin  String @default("")
  github    String @default("")
  youtube   String @default("")
  instagram String @default("")

  updatedAt DateTime @updatedAt
}

model Settings {
  id                  String  @id @default("settings")
  siteTitle           String  @default("CuratedStack")
  logoUrl             String  @default("")
  faviconUrl          String  @default("")
  defaultSeoTitle     String  @default("CuratedStack – Tools & Insights for Digital Builders")
  defaultSeoDescription String @default("Curated tools, honest reviews, and practical guides for makers building their next project.")
  analyticsId         String  @default("")

  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Media & activity log
// ---------------------------------------------------------------------------

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String // e.g. "post.created", "tool.updated"
  entity    String // e.g. "Post", "Tool"
  entityId  String?
  detail    String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entity])
}
